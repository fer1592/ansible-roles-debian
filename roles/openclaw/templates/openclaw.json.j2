{
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "port": 18789,
    "trustedProxies": {{ openclaw_trusted_proxies | default([]) | to_json }},
    "controlUi": {
      "enabled": true,
      "allowedOrigins": {{ openclaw_allow_origins | default([]) | to_json }},
      "dangerouslyDisableDeviceAuth": {{ openclaw_disable_device_auth | default(false) }}
    }
  },

  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/workspace"
    }
  }
}